{
  "expo": {
    "name": "Doodh Wala",
    "slug": "Doodh-Wala",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "dailydoodh",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saket121122.DailyDoodh"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.jpg",
          "imageWidth": "100%",
          "resizeMode": "cover",
          "backgroundColor": "#fff",
          "dark": {
            "backgroundColor": "#fff"
          }
        }
      ],
      "expo-font",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "saket121122",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c1c5e18e-0c33-4d10-a4df-77dd8ebe6cd2"
      }
    }
  }
}
